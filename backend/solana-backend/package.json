{
  "name": "solana-backend",
  "version": "1.0.0",
  "description": "Solana backend for event indexing and API",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "script": "ANCHOR_PROVIDER_URL=https://api.devnet.solana.com ANCHOR_WALLET=~/.config/solana/id.json tsx",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:init": "tsx scripts/db/init-db.ts",
    "db:reset": "prisma migrate reset"
  },
  "keywords": [
    "solana",
    "backend",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.6.3",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.0",
    "prisma": "^7.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@prisma/adapter-better-sqlite3": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@solana/rpc": "^5.0.0",
    "@solana/web3.js": "^1.98.4",
    "axios": "^1.13.2",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "bufferutil",
      "esbuild",
      "prisma",
      "utf-8-validate"
    ],
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "bufferutil",
      "esbuild",
      "prisma",
      "utf-8-validate"
    ]
  }
}
