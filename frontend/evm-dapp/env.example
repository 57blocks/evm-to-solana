# Environment Variables
# Copy this file to .env and fill in your actual values

# Alchemy RPC URL for Sepolia testnet
# Get your API key from https://www.alchemy.com/
VITE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# The Graph API Key for subgraph queries
# Get your API key from https://thegraph.com/studio/
VITE_GRAPH_API_KEY=your_graph_api_key_here

# The Graph URL
VITE_GRAPH_URL=your_graph_url