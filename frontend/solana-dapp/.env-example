# Environment Variables
# Copy this file to .env.local and fill in your actual values

# Optionally specify a custom Solana RPC endpoint, e.g. via Helius or another provider.
# If VITE_CUSTOM_RPC_URL is left blank or undefined, the app will default to the official Solana Devnet endpoint.
# Example Helius RPC: https://rpc.helio.solana.com
VITE_CUSTOM_RPC_URL=SOLANA_RPC_ENDPOINT